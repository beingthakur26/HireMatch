rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profile Validation ---
    function isValidUserProfile(data) {
      return data.userId == request.auth.uid
        && data.email is string
        && (data.name == null || (data.name is string && data.name.size() <= 100))
        && (data.skills == null || (data.skills is list && data.skills.size() <= 100))
        && (data.experience == null || (data.experience is list && data.experience.size() <= 50))
        && (data.education == null || (data.education is list && data.education.size() <= 20));
    }

    // --- Job Validation ---
    function isValidJob(data) {
      return data.title is string && data.title.size() <= 200
        && data.company is string && data.company.size() <= 200
        && (data.matchScore == null || (data.matchScore is number && data.matchScore >= 0 && data.matchScore <= 100));
    }

    // --- Job Alert Validation ---
    function isValidJobAlert(data) {
      return data.keywords is string && data.keywords.size() <= 100
        && (data.frequency in ['daily', 'weekly', 'instant'])
        && data.isActive is bool;
    }

    // --- Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) 
                     && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUserProfile(incoming())
                     && incoming().createdAt == existing().createdAt
                     && incoming().updatedAt == request.time
                     && incoming().diff(existing()).affectedKeys().hasOnly([
                       'name', 'title', 'phone', 'about', 'skills', 'experience', 
                       'education', 'profilePicture', 'resume', 'updatedAt', 'userId', 'email'
                     ]);
      
      match /savedJobs/{jobId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidJob(incoming()) && isValidId(jobId);
        allow delete: if isOwner(userId);
      }

      match /jobAlerts/{alertId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidJobAlert(incoming()) && isValidId(alertId);
        allow update: if isOwner(userId) && isValidJobAlert(incoming())
                       && incoming().diff(existing()).affectedKeys().hasOnly(['keywords', 'location', 'frequency', 'isActive']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
